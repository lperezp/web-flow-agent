# Clave de API de Gemini para el razonamiento inteligente del agente de QA
# Consíguela en Google AI Studio: https://aistudio.google.com/app/api-keys
GEMINI_API_KEY="tu-api-key-aqui"

# Modelo de Gemini a utilizar (opcional, por defecto: gemini-1.5-flash)
# Puedes cambiarlo a gemini-1.5-pro si necesitas razonamiento más complejo
GEMINI_MODEL="gemini-1.5-flash"
